# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_USER=evoting_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=evoting

# ── Backend ────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://evoting_user:change_me_in_production@localhost:5432/evoting
REDIS_URL=redis://localhost:6379/0
PULSAR_URL=pulsar://localhost:6650

# ── Security ───────────────────────────────────────────────────
SECRET_KEY=replace_with_64_char_random_hex_string
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# ── Face Matching ──────────────────────────────────────────────
FACE_SIMILARITY_THRESHOLD=0.85

# ── UTI Lifecycle ──────────────────────────────────────────────
UTI_TTL_SECONDS=86400
LIVENESS_NONCE_TTL_SECONDS=90