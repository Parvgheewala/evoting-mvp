{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["nativewind/types"]   // 👈 ADD THIS
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    ".expo/types/**/*.d.ts",
    "nativewind-env.d.ts",          // 👈 ADD THIS TOO
    "global.d.ts"
  
  ]
}
