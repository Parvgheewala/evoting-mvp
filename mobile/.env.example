# Backend API Configuration for Expo
# NOTE: Expo apps use app.json for environment variables, not .env files
# Update the "extra" section in app.json instead of this file

# For development, use localhost:8000 (Docker containers accessible from host)
# For production or remote testing, use your server's IP/domain

# These values should be set in app.json under "expo.extra":
# {
#   "extra": {
#     "BASE_URL": "http://localhost:8000",
#     "API_VERSION": "/api/v1",
#     "TIMEOUT_MS": 10000
#   }
# }

# For mobile device testing: Replace 'localhost' with your host machine IP
# Run: ipconfig (Windows) or ifconfig (Linux/Mac) to find your IP
# Example: BASE_URL=http://192.168.1.100:8000

# This file is for reference only - actual config is in app.json
