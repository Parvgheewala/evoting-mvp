# Auto normalize text files
* text=auto

# Force LF for code (important for Docker, Linux, CI)
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.py text eol=lf

# Windows-specific files
*.bat text eol=crlf
*.cmd text eol=crlf